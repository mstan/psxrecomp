# BIOS ROM (copyrighted, not distributable)
bios/

# DuckStation — upstream source is a git submodule pointing at stenzek/duckstation.
# Our custom changes live in tools/duckstation/psxrecomp_oracle.patch (committed).
# Only the build artefacts and prebuilt binary deps are untracked at the parent level;
# the submodule's own .gitignore handles in-tree ignores.
duckstation/build/
duckstation/dep/prebuilt/

# Ghidra project files (large, regenerable)
ghidra/

# Build artifacts
recompiler/build/
runtime/build/
generated/*.o
generated/*.obj

# Runtime diagnostic/crash files
psx_crash.txt
psx_diag.txt
psx_dispatch_misses.txt
psx_err.txt
psx_out.txt

# Probe / scratch artifacts
# All ad-hoc diagnostic dumps land under probes/ so the repo root stays clean.
# Runtime data (memcards) is intentionally NOT covered: card*.mcd, dummy.*.mcr.
probes/
/*.json
/*.png
/*.bmp
/*.txt

# OS / editor junk
.DS_Store
Thumbs.db
*.swp
*.swo
*~
